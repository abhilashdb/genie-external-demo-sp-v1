# ============================================================
# Genie Space SP Demo — environment variables
# ------------------------------------------------------------
# Copy to `.env` and fill in values. `.env` is gitignored.
# The backend loads these via python-dotenv at startup.
# ============================================================

# ----- Databricks workspace (e2-demo) -----
DBX_HOST=https://<your-workspace>.cloud.databricks.com
DBX_PROFILE=<cli profile configured via `databricks auth login`>
DBX_WAREHOUSE_ID=<serverless SQL warehouse id>

# Unity Catalog target for the demo data
DBX_CATALOG=abhilash_r
DBX_SCHEMA=genie_demo

# ----- Genie space -----
# Created AFTER synthetic data is seeded (needs table refs).
# Leave blank; the setup script will populate this and echo an export line.
GENIE_SPACE_ID=

# ----- Service Principals (one per dealership) -----
# Get client_id (applicationId) from: databricks service-principals create
# Get secret from: databricks service-principal-secrets-proxy create <app-id>
# Secrets shown only once — capture immediately.

SP_NORTHSTAR_CLIENT_ID=
SP_NORTHSTAR_SECRET=
SP_NORTHSTAR_DEALERSHIP="North Star Motors"
# applicationId is the same as client_id for OAuth SPs; used for RLS current_user() matching.
SP_NORTHSTAR_APP_ID=

SP_SUNRISE_CLIENT_ID=
SP_SUNRISE_SECRET=
SP_SUNRISE_DEALERSHIP="Sunrise Auto Group"
SP_SUNRISE_APP_ID=

# ----- Local session / app config -----
# Random 32+ char string used to sign session cookies.
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'
APP_SESSION_SECRET=

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ----- Local test users -----
# Seed users are defined in backend/users.py — no env var needed.
# Default passwords live there for the demo; change before sharing.
